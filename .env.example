# Application
ENV=development
PORT=8080
LOG_LEVEL=info
LOG_DIR=logs/api
LOG_FILE=app.log

# PostgreSQL (matches deploy/docker-compose.yml defaults)
DATABASE_URL=postgres://nexuslink:nexuslink@localhost:5432/nexuslink?sslmode=disable

# Public base URL used in short_url responses
BASE_URL=http://localhost:8080
